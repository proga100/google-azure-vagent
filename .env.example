# ============================================================================
# Google + Azure English Voice Agent — PUBLIC DEMO environment
# Gemini Live (STT + LLM) with a switchable voice: Gemini timbres or Azure en-US
# neural voices. Public demo → keep the cost guards (DEMO_WORD_LIMIT, concurrency).
# ============================================================================

PROVIDER=google

# ---- Google / Gemini auth ----
# API key for the Gemini Developer API (Gemini text + Live API):
GEMINI_API_KEY=
# (Only needed for the staged Cloud STT path; the demo uses Gemini Live STT.)
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_PROJECT_ID=
GOOGLE_GENAI_USE_VERTEXAI=false

# ---- STT: Cloud Speech-to-Text v2 (staged path only) ----
GOOGLE_STT_REGION=europe-west4
GOOGLE_STT_LANGUAGE=en-US
GOOGLE_STT_MODEL=chirp_2

# ---- LLM: Gemini text (staged path only) ----
GEMINI_MODEL=gemini-3.5-flash
GEMINI_TEMPERATURE=0.3
GEMINI_MAX_TOKENS=120

# ---- Speech-out path ----
USE_GEMINI_LIVE_AUDIO=true
TTS_PROVIDER=gemini_live

# ---- Gemini Live API ----
# Half-cascade Live model: ~1.3s to first audio, honours language_code (en-US).
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
GEMINI_LIVE_LANGUAGE=en-US
GEMINI_LIVE_VOICE=Aoede

# ---- External TTS fallback (only when TTS_PROVIDER=external) ----
EXTERNAL_TTS_URL=
EXTERNAL_TTS_VOICE=

# ---- Azure Neural TTS (powers the "azure:" voice pills, e.g. en-US-AvaNeural) ----
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus

# ---- Public demo cost guards ----
DEMO_MODE=true
DEMO_WORD_LIMIT=15
DEMO_MAX_CONCURRENT_SESSIONS=8

# ---- Audio ----
AUDIO_INPUT_SAMPLE_RATE_HZ=16000
AUDIO_OUTPUT_SAMPLE_RATE_HZ=24000
TTS_VOICE=Aoede

# ---- Voice pipeline ----
VOICE_PIPELINE_MODE=google_azure_en_demo
VOICE_TRANSPORT=websocket
VOICE_ENABLE_BARGE_IN=true
VOICE_ENABLE_FILLER=true
VOICE_ENDPOINT_SILENCE_MS=500

# ---- App auth / CORS ----
# Empty = open WebSocket (public demo). Set a value to require ?token=<value>.
VOICE_API_TOKEN=
# Backend 8013 / client 3011 (so it runs alongside the other local agents).
CORS_ORIGINS=http://localhost:3011,http://127.0.0.1:3011

# ---- Input noise gate ----
VOICE_INPUT_GATE_ENABLED=true
VOICE_INPUT_GATE_THRESHOLD=0.02
VOICE_INPUT_GATE_HANGOVER_MS=600
