# ============================================================================
# Google Uzbek Voice Agent — environment
# NOTE: Google Cloud Text-to-Speech has NO Uzbek voice. Spoken Uzbek comes from
# the Gemini Live API (uz-UZ). Do not set a fake uz-UZ Cloud TTS voice name.
# ============================================================================

PROVIDER=google

# ---- Google / Gemini auth ----
# API key for the Gemini Developer API (Gemini text + Live API):
GEMINI_API_KEY=
# Service-account JSON for Cloud Speech-to-Text (ADC):
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_PROJECT_ID=
# Use Vertex AI for Gemini instead of an API key (uses ADC + project):
GOOGLE_GENAI_USE_VERTEXAI=false

# ---- STT: Cloud Speech-to-Text v2 (Uzbek via chirp/chirp_2) ----
# chirp_2 serves uz-UZ in asia-southeast1 and europe-west4 only.
GOOGLE_STT_REGION=europe-west4
GOOGLE_STT_LANGUAGE=uz-UZ
GOOGLE_STT_MODEL=chirp_2

# ---- LLM: Gemini text ----
GEMINI_MODEL=gemini-3.5-flash
GEMINI_TEMPERATURE=0.3
GEMINI_MAX_TOKENS=120

# ---- Speech-out path ----
# Run the whole conversation over Gemini Live realtime audio (preferred path):
USE_GEMINI_LIVE_AUDIO=true
# Staged-pipeline TTS strategy (used when USE_GEMINI_LIVE_AUDIO=false):
#   gemini_live | external | none
TTS_PROVIDER=gemini_live

# ---- Gemini Live API (the only Google path to Uzbek voice) ----
# Native-audio model: auto-detects language, speaks Uzbek when prompted in Uzbek
# (verified). Does NOT accept a language_code. List Live models for your key with
# the supported_actions=bidiGenerateContent filter.
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
# Only applied to non-native (half-cascade) Live models:
GEMINI_LIVE_LANGUAGE=uz-UZ
GEMINI_LIVE_VOICE=Aoede

# ---- External Uzbek TTS fallback (only when TTS_PROVIDER=external) ----
# e.g. an Azure uz-UZ voice service or a self-hosted Chatterbox/FeruzaSpeech.
EXTERNAL_TTS_URL=
EXTERNAL_TTS_VOICE=

# ---- Azure Neural TTS (native Uzbek; powers the "azure:" voice buttons) ----
# When the client picks an azure: voice, Gemini Live does STT+LLM (TEXT) and
# Azure speaks the reply with a real uz-UZ voice (Madina/Sardor) — no accent.
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus

# ---- Audio ----
AUDIO_INPUT_SAMPLE_RATE_HZ=16000
AUDIO_OUTPUT_SAMPLE_RATE_HZ=24000
TTS_VOICE=Aoede

# ---- Optional Russian bridge (OFF: Gemini handles Uzbek directly) ----
VOICE_USE_RUSSIAN_BRIDGE=false
BRIDGE_USER_LANG=uz
BRIDGE_MODEL_LANG=ru

# ---- Voice pipeline ----
VOICE_PIPELINE_MODE=google_gemini_live
VOICE_TRANSPORT=websocket
VOICE_ENABLE_BARGE_IN=true
VOICE_ENABLE_FILLER=true
VOICE_ENDPOINT_SILENCE_MS=500

# ---- App auth / CORS ----
# Leave empty to open /ws/voice without a token (local testing). Set a value to
# require ?token=<value> on the WebSocket.
VOICE_API_TOKEN=
# Backend 8012 / client 3010 so this runs alongside the Yandex agent.
CORS_ORIGINS=http://localhost:3010,http://127.0.0.1:3010

# ---- Input noise gate (raise threshold = less mic sensitivity) ----
VOICE_INPUT_GATE_ENABLED=true
VOICE_INPUT_GATE_THRESHOLD=0.02
VOICE_INPUT_GATE_HANGOVER_MS=600
